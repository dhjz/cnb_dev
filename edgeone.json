{
    "headers": [
        {
            "source": "/v1/*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                },
                {
                    "key": "X-Accel-Buffering",
                    "value": "no"
                },
                {
                    "key": "Content-Encoding",
                    "value": "identity"
                },
                {
                    "key": "Connection",
                    "value": "keep-alive"
                }
            ]
        },
        {
            "source": "/chat/*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                },
                {
                    "key": "X-Accel-Buffering",
                    "value": "no"
                },
                {
                    "key": "Content-Encoding",
                    "value": "identity"
                },
                {
                    "key": "Connection",
                    "value": "keep-alive"
                }
            ]
        },
        {
            "source": "/*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "max-age=7200"
                }
            ]
        }
    ]
}